# AI学术论文监控系统 - 环境变量配置模板
# AI Academic Paper Monitoring System - Environment Variables Template

# 复制此文件为 .env 并修改相应配置
# Copy this file to .env and modify the configurations

# ==================== 数据库配置 Database Configuration ====================
# 数据库文件路径
DATABASE_PATH=data/papers.db

# 数据库备份设置
DATABASE_BACKUP_ENABLED=true
DATABASE_BACKUP_INTERVAL_DAYS=7

# ==================== 日志配置 Logging Configuration ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/paper_monitor.log

# 日志文件最大大小 (MB)
LOG_MAX_SIZE_MB=10

# 保留的日志文件数量
LOG_BACKUP_COUNT=5

# ==================== 网络代理配置 Proxy Configuration ====================
# 是否启用代理 (true/false)
PROXY_ENABLED=false

# HTTP代理地址 (如需要)
HTTP_PROXY=http://127.0.0.1:7890

# HTTPS代理地址 (如需要)
HTTPS_PROXY=http://127.0.0.1:7890

# 代理用户名 (如需要)
PROXY_USERNAME=

# 代理密码 (如需要)
PROXY_PASSWORD=

# ==================== Chrome浏览器配置 Chrome Configuration ====================
# 是否使用无头模式 (true/false)
CHROME_HEADLESS=true

# 是否禁用GPU (true/false)
CHROME_DISABLE_GPU=true

# 是否禁用沙箱 (true/false)
CHROME_NO_SANDBOX=true

# Chrome窗口大小
CHROME_WINDOW_SIZE=1920,1080

# Chrome驱动路径 (留空自动下载)
CHROME_DRIVER_PATH=

# ==================== API配置 API Configuration ====================
# 是否启用学术搜索API (true/false)
SCHOLARLY_ENABLED=false

# 学术搜索API延迟 (秒)
SCHOLARLY_DELAY=5

# 是否启用ArXiv API (true/false)
ARXIV_ENABLED=false

# ArXiv API延迟 (秒)
ARXIV_DELAY=3

# Google Scholar API密钥 (如有)
GOOGLE_SCHOLAR_API_KEY=

# ==================== 爬虫配置 Crawler Configuration ====================
# 请求超时时间 (秒)
REQUEST_TIMEOUT=30

# 最大重试次数
MAX_RETRIES=5

# 重试延迟 (秒)
RETRY_DELAY=10

# 请求间隔 (秒)
REQUEST_INTERVAL=2

# User-Agent字符串
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36

# ==================== 评分系统配置 Scoring System Configuration ====================
# 引用数据权重
CITATION_WEIGHT=0.25

# 引用增长率权重
CITATION_GROWTH_WEIGHT=0.20

# 作者H指数权重
AUTHOR_H_INDEX_WEIGHT=0.15

# 会议影响因子权重
VENUE_IMPACT_WEIGHT=0.15

# 新颖性评分权重
NOVELTY_WEIGHT=0.10

# 技术深度权重
TECHNICAL_DEPTH_WEIGHT=0.10

# 商业潜力权重
COMMERCIAL_POTENTIAL_WEIGHT=0.05

# 投资评分阈值
INVESTMENT_SCORE_THRESHOLD=7.0

# ==================== 邮件通知配置 Email Notification Configuration ====================
# 是否启用邮件通知 (true/false)
EMAIL_ENABLED=false

# SMTP服务器地址
SMTP_SERVER=smtp.gmail.com

# SMTP端口
SMTP_PORT=587

# 发送者邮箱
SENDER_EMAIL=your-email@gmail.com

# 发送者密码或应用密码
SENDER_PASSWORD=your-app-password

# 接收者邮箱列表 (用逗号分隔)
RECIPIENT_EMAILS=investor1@example.com,investor2@example.com

# 通知频率: daily, weekly, monthly
NOTIFICATION_FREQUENCY=weekly

# ==================== Excel导出配置 Excel Export Configuration ====================
# 报告文件名模板
EXCEL_FILENAME_TEMPLATE=AI_Papers_Analysis_{date}.xlsx

# 表头颜色 (十六进制)
EXCEL_HEADER_COLOR=366092

# 高亮颜色 (十六进制)
EXCEL_HIGHLIGHT_COLOR=FFE699

# 字体名称
EXCEL_FONT_NAME=Calibri

# 字体大小
EXCEL_FONT_SIZE=11

# ==================== Web界面配置 Web Interface Configuration ====================
# Streamlit端口
STREAMLIT_PORT=8501

# 是否启用调试模式 (true/false)
DEBUG_MODE=false

# 页面标题
PAGE_TITLE=AI学术论文监控系统

# 页面图标
PAGE_ICON=📊

# ==================== 安全配置 Security Configuration ====================
# API密钥 (用于保护API访问)
API_KEY=your-secret-api-key

# JWT密钥 (用于用户认证)
JWT_SECRET_KEY=your-jwt-secret-key

# 会话超时时间 (小时)
SESSION_TIMEOUT_HOURS=24

# ==================== 缓存配置 Cache Configuration ====================
# 是否启用缓存 (true/false)
CACHE_ENABLED=true

# 缓存过期时间 (小时)
CACHE_EXPIRY_HOURS=24

# 缓存目录
CACHE_DIR=cache/

# ==================== 开发模式配置 Development Configuration ====================
# 是否为开发模式 (true/false)
DEV_MODE=false

# 是否启用详细日志 (true/false)
VERBOSE_LOGGING=false

# 是否启用性能分析 (true/false)
PROFILING_ENABLED=false

# 测试数据库路径
TEST_DATABASE_PATH=data/test_papers.db

# ==================== 第三方服务配置 Third-party Service Configuration ====================
# OpenReview API配置
OPENREVIEW_API_URL=https://api.openreview.net

# CVF API配置
CVF_API_URL=https://openaccess.thecvf.com

# Semantic Scholar API密钥
SEMANTIC_SCHOLAR_API_KEY=

# CrossRef API邮箱 (用于礼貌性请求)
CROSSREF_EMAIL=your-email@example.com

# ==================== 监控和告警配置 Monitoring and Alerting Configuration ====================
# 是否启用系统监控 (true/false)
MONITORING_ENABLED=false

# 监控检查间隔 (分钟)
MONITORING_INTERVAL_MINUTES=30

# 错误阈值 (连续错误次数)
ERROR_THRESHOLD=5

# 告警邮箱
ALERT_EMAIL=admin@example.com

# ==================== 备份配置 Backup Configuration ====================
# 自动备份间隔 (天)
AUTO_BACKUP_INTERVAL_DAYS=7

# 备份保留天数
BACKUP_RETENTION_DAYS=30

# 备份目录
BACKUP_DIR=backups/

# 是否压缩备份 (true/false)
BACKUP_COMPRESS=true

# ==================== 其他配置 Other Configuration ====================
# 时区设置
TIMEZONE=Asia/Shanghai

# 语言设置
LANGUAGE=zh-CN

# 最大并发数
MAX_CONCURRENT_REQUESTS=5

# 数据保留天数
DATA_RETENTION_DAYS=365